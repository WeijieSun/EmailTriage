# email-triage Outlook credentials
#
# Copy this file to `.env` and fill in the values from your Azure App registration.
# See docs/outlook-setup.md for step-by-step instructions.
#
# `.env` is gitignored — never commit real credentials.

# REQUIRED. The Application (client) ID from your Azure App registration.
# Looks like a GUID, e.g. 11111111-2222-3333-4444-555555555555
# Shared Azure App — supports any personal Microsoft account (outlook.com).
# Each user logs in with their OWN Outlook account via device-code flow.
# The client_id is public and safe to share.
OUTLOOK_CLIENT_ID=ee180a89-ed8d-40c1-8edf-43514eed0654

# consumers = personal outlook.com accounts
OUTLOOK_TENANT_ID=consumers
